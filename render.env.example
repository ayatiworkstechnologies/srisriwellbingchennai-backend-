# Copy these keys into Render Dashboard > Backend Service > Environment.
# Do not commit real production passwords or secrets.

DATABASE_URL=mysql+pymysql://USER:PASSWORD@HOST:3306/DBNAME
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PASSWORD_RESET_EXPIRE_MINUTES=30
ADMIN_EMAIL=admin@srisriwellbeingchennai.com
ADMIN_PASSWORD=replace-with-secure-admin-password
SEED_DEFAULT_CONTENT=false
PROJECT_NAME=Sri Sri Wellbeing Chennai API

FRONTEND_ORIGIN=http://localhost:3000,https://srisriwellbeingchennai.vercel.app,https://srisriwellbeingchennai.com,https://www.srisriwellbeingchennai.com
FRONTEND_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1)(:\d+)?$|^https://.*\.vercel\.app$
ADMIN_RESET_PASSWORD_URL=https://srisriwellbeingchennai.com/admin/reset-password
ADMIN_LOGIN_URL=https://srisriwellbeingchennai.com/admin/login

MAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=ayatiworkstechnologies@gmail.com
SMTP_USER=ayatiworkstechnologies@gmail.com
SMTP_PASSWORD=replace-with-gmail-app-password
SMTP_PASS=replace-with-gmail-app-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=20
SMTP_LOCAL_HOSTNAME=
SMTP_FROM_EMAIL=ayatiworkstechnologies@gmail.com
SMTP_FROM_NAME=Sri Sri Wellbeing Chennai
SMTP_REPLY_TO_EMAIL=rubankumar@ayatiworks.com

# Render sets this automatically on hosted services, but keeping it explicit is fine.
RENDER=true
